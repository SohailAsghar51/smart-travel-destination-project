# Copy to .env and fill in. Flask does not auto-load .env unless you `pip install python-dotenv` and load it; this file is documentation.

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=Pass456
DB_NAME=ai_travel_buddy

# Create smart_travel_backend/.env in THIS folder and set the key.
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=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
# If one model fails, try: llama-3.1-8b-instant, mixtral-8x7b-32768, etc.
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: weather — RapidAPI "Open Weather 13" (https://rapidapi.com/worldapi/api/open-weather13)
# Subscribe in RapidAPI, paste your x-rapidapi-key here (same as Postman "X-RapidAPI-Key").
RAPIDAPI_KEY=1e9a1071a6mshb3562830aa509d6p1b9a08jsn464bf3bfd152

# Map preview images use OpenStreetMap (staticmap.openstreetmap.de) — no API key.

PORT=5000
